# Copy to .env and fill in values
# Never commit .env to git

DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/political_fantasy

# Free key — get at https://www.propublica.org/datastore/api/propublica-congress-api
PROPUBLICA_API_KEY=your_key_here

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_jwt_secret_here

# Supabase (optional auth provider)
SUPABASE_URL=
SUPABASE_ANON_KEY=
